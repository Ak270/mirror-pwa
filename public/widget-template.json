{
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🪞 Mirror",
                  "weight": "Bolder",
                  "size": "Medium",
                  "color": "Accent"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${date}",
                  "size": "Small",
                  "color": "Default",
                  "horizontalAlignment": "Right"
                }
              ]
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${completionText}",
          "size": "Small",
          "color": "Good",
          "spacing": "Medium"
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "FactSet",
          "facts": "${habits}"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open Mirror",
      "url": "${appUrl}/log"
    }
  ]
}
